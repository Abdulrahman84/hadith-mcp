{
  "name": "@hadith-mcp/data",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Hadith data import, validation, and SQLite build package.",
  "exports": {
    ".": "./dist/index.js"
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "audit:hadith-api": "npm run build && node dist/audit-hadith-api.js --out-dir ../../data/generated",
    "build:fixture-sqlite": "npm run build && node dist/build-fixture-sqlite.js",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
