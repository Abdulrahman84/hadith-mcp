{
  "name": "hadith-mcp-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "audit:hadith-api": "npm run audit:hadith-api -w @hadith-mcp/data",
    "audit:maktaba-grades-backup": "npm run audit:maktaba-grades-backup -w @hadith-mcp/data",
    "audit:meeatif-hadith-datasets": "npm run audit:meeatif-hadith-datasets -w @hadith-mcp/data",
    "audit:open-hadith-data": "npm run audit:open-hadith-data -w @hadith-mcp/data",
    "build:meeatif-sqlite": "npm run build:meeatif-sqlite -w @hadith-mcp/data",
    "build:fixture-sqlite": "npm run build:fixture-sqlite -w @hadith-mcp/data",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^24.0.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
